<Window x:Class="football_project.DialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="340" Height="170"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Border Background="White" CornerRadius="10"
            BorderBrush="#3F0071" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.18"
                              BlurRadius="20" ShadowDepth="4"/>
        </Border.Effect>

        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtMessage"
                       Grid.Row="0"
                       TextWrapping="Wrap"
                       FontSize="14"
                       Foreground="#1A1A1A"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">

                <Button x:Name="btnNo"
                        Content="NO"
                        Width="80" Height="32"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Click="btnNo_Click"
                        Background="Transparent"
                        Foreground="#3F0071"
                        FontWeight="SemiBold"
                        BorderBrush="#3F0071"
                        BorderThickness="1.5"
                        Cursor="Hand"/>

                <Button x:Name="btnYes"
                        Content="OK"
                        Width="80" Height="32"
                        Click="btnYes_Click"
                        Background="#3F0071"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>